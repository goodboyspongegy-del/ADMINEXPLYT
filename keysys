local function getOrCreate(par, class, name)
	return par:FindFirstChild(name) or (function()
		local o = Instance.new(class, par); o.Name = name; return o
	end)()
end

local AdminNotif  = getOrCreate(AdminFolder, "RemoteEvent",    "AdminNotification")
local ValidateKey = getOrCreate(AdminFolder, "RemoteFunction", "ValidateKey")

-- ══════════════════════════════════════════════════════════════════
--  HELPERS
-- ══════════════════════════════════════════════════════════════════
local function isOwner(p)
	for _, id in ipairs(OWNER_IDS) do if p.UserId == id then return true end end
	return false
end

local function notify(p, msg, t)
	pcall(function() AdminNotif:FireClient(p, msg, t or "info") end)
end

local function notifyOwners(msg)
	for _, p in ipairs(Players:GetPlayers()) do
		if isOwner(p) then notify(p, msg, "warning") end
	end
end

-- ══════════════════════════════════════════════════════════════════
--  KEY VALIDATION
-- ══════════════════════════════════════════════════════════════════
ValidateKey.OnServerInvoke = function(player, inputUser, inputKey)
	if not player or not player.Parent then
		return {success=false, reason="Error — try again."}
	end

	local u = tostring(inputUser or ""):lower():gsub("%s","")
	local k = tostring(inputKey  or ""):lower():gsub("%s","")

	if u=="" or k=="" then
		return {success=false, reason="Please fill in both fields."}
	end

	-- Already authed this session
	if UsedSessions[player.UserId] then
		return {success=true, tier=UsedSessions[player.UserId], isOwner=isOwner(player)}
	end

	-- Owner key — always works
	if u==OWNER_USER and k==OWNER_KEY then
		UsedSessions[player.UserId] = "Owner"
		notifyOwners("🔑 Owner login: "..player.Name)
		return {success=true, tier="Owner", isOwner=true}
	end

	-- Check generated keys table
	for _, entry in ipairs(VALID_KEYS) do
		local eu = tostring(entry.username or ""):lower():gsub("%s","")
		local ek = tostring(entry.key     or ""):lower():gsub("%s","")
		if eu==u and ek==k then
			UsedSessions[player.UserId] = entry.tier or "VIP"
			notifyOwners("🔑 "..player.Name.." logged in ["..entry.tier.."] as "..entry.username)
			return {success=true, tier=entry.tier or "VIP", isOwner=false}
		end
	end

	-- Rejected — key not in table, random guess rejected
	notifyOwners("⚠ Failed login by "..player.Name.." (wrong credentials)")
	return {success=false, reason="Invalid username or key. Keys must come from the admin portal."}
end


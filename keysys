--  LIVE KEY SYNC — polls Google Apps Script backend every 30s
--  Paste your Apps Script deployment URL below
-- ══════════════════════════════════════════════════════════════════
local BACKEND_URL = "YOUR_GOOGLE_APPS_SCRIPT_URL_HERE"
local BACKEND_TOKEN = "AAPK_SECRET_2024_KSHUSHA" -- must match Apps Script

local function syncKeys()
	if BACKEND_URL == "YOUR_GOOGLE_APPS_SCRIPT_URL_HERE" then return end
	local ok, result = pcall(function()
		local response = game:GetService("HttpService"):GetAsync(
			BACKEND_URL .. "?action=get_keys&token=" .. BACKEND_TOKEN, true
		)
		local data = game:GetService("HttpService"):JSONDecode(response)
		if data and data.success and data.keys then
			-- Merge new keys in (don't remove existing ones)
			local existing = {}
			for _, k in ipairs(VALID_KEYS) do existing[k.username] = true end
			local added = 0
			for _, k in ipairs(data.keys) do
				if not existing[k.username] then
					table.insert(VALID_KEYS, {
						username = k.username,
						key      = k.key,
						tier     = k.tier or "VIP"
					})
					existing[k.username] = true
					added = added + 1
				end
			end
			if added > 0 then
				print("[A.APK.PANEL] 🔑 Synced "..added.." new key(s) from backend. Total: "..#VALID_KEYS)
			end
		end
	end)
	if not ok then
		warn("[A.APK.PANEL] Key sync failed: "..tostring(result))
	end
end

-- Sync on startup then every 30 seconds
task.spawn(function()
	task.wait(3)
	syncKeys()
	while true do
		task.wait(30)
		syncKeys()
	end
end)

-- ── BUBBLE CHAT COMMAND ───────────────────────────────────────────
-- Uses BOTH real Roblox chat (SayMessage via Chat service) AND visual bubble
Commands.bubblechat = function(a, n, msg, colName, fontSize, duration)
	local targets = {}
	if n and n ~= "" and n ~= "all" then
		local t = getP(n); if not t then return false,"Player not found" end
		table.insert(targets, t)
	else
		for _,p in ipairs(Players:GetPlayers()) do table.insert(targets,p) end
	end
	msg = tostring(msg or "..."):sub(1,200)

	local successCount = 0
	for _, t in ipairs(targets) do
		-- Visual bubble GUI (always works)
		sendBubble(t, msg, colName or "white", tonumber(fontSize) or 14, tonumber(duration) or 8, a.Name)
		-- Real chat message via Chat service (appears in chat log)
		pcall(function()
			-- This uses TextChatService if available, else Chat:Chat
			local suc = pcall(function()
				Chat:Chat(t.Character and t.Character:FindFirstChild("Head") or t.Character, msg, Enum.ChatColor.White)
			end)
		end)
		successCount = successCount + 1
	end
	logAction(a,"BUBBLECHAT → "..msg:sub(1,30),(n and n~="" and n or "all"))
	return true,"Bubble sent to "..successCount.." player(s): "..msg:sub(1,40)
end


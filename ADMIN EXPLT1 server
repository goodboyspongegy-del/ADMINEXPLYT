--  HEARTBEAT: enforce frozen / cuffed / jailed / god / invisible
-- ══════════════════════════════════════════════════════════════════
RunSvc.Heartbeat:Connect(function()
	-- Jailed players stay at (0,150,0)
	for uid in pairs(Jailed) do
		local p=Players:GetPlayerByUserId(uid)
		local h=p and getHRP(p)
		if h and (h.Position-Vector3.new(0,150,0)).Magnitude>22 then h.CFrame=CFrame.new(0,150,0) end
	end
	-- Cuffed players can't move
	for uid in pairs(Cuffed) do
		local p=Players:GetPlayerByUserId(uid)
		local h=p and getHum(p)
		if h then h.WalkSpeed=0;h.JumpPower=0 end
	end
	-- God mode players stay at full health
	for uid in pairs(GodMode) do
		local p=Players:GetPlayerByUserId(uid)
		local h=p and getHum(p)
		if h and h.MaxHealth~=math.huge then h.MaxHealth=math.huge end
		if h and h.Health<h.MaxHealth then h.Health=h.MaxHealth end
	end
	-- Invisible players stay invisible on respawn
	for uid in pairs(Invisible) do
		local p=Players:GetPlayerByUserId(uid)
		local c=p and p.Character
		if c then
			for _,pt in ipairs(c:GetDescendants()) do if pt:IsA("BasePart") then pt.Transparency=1 end end
		end
	end
end)


--  GLOBAL PLAYER SEARCH (searches entire game, not just this server)
-- ══════════════════════════════════════════════════════════════════
SearchQuery.OnServerInvoke = function(player, query)
	if not isAdmin(player) then return {success=false, results={}} end
	if not query or #query < 2 then return {success=false, results={}} end

	local results = {}
	local lo = query:lower()

	-- First search current server players (fast)
	for _, p in ipairs(Players:GetPlayers()) do
		local pn = p.Name:lower()
		local dn = p.DisplayName:lower()
		if pn:find(lo,1,true) or dn:find(lo,1,true) then
			table.insert(results, {
				Name        = p.Name,
				DisplayName = p.DisplayName,
				UserId      = p.UserId,
				InServer    = true,
				HP          = 0, WalkSpeed = 0,
			})
			-- Fill HP/speed
			local h=getHum(p)
			if h then results[#results].HP=math.floor(h.Health); results[#results].WalkSpeed=math.floor(h.WalkSpeed) end
		end
	end

	-- Then try global search via Players:GetUserIdFromNameAsync for exact names
	-- and Players:GetPlayerByUserId for ID searches
	local alreadyFound = {}
	for _,r in ipairs(results) do alreadyFound[r.Name]=true end

	-- If query looks like a number, search by UserId
	local uid = tonumber(query)
	if uid then
		local ok, info = pcall(function()
			return Players:GetNameFromUserIdAsync(uid)
		end)
		if ok and info and not alreadyFound[info] then
			local ok2, avId = pcall(function()
				return Players:GetUserIdFromNameAsync(info)
			end)
			table.insert(results, {
				Name        = info,
				DisplayName = info,
				UserId      = uid,
				InServer    = false,
				HP=0, WalkSpeed=0
			})
		end
	end

	-- Try exact username lookup
	local ok, foundId = pcall(function()
		return Players:GetUserIdFromNameAsync(query)
	end)
	if ok and foundId and not alreadyFound[query] then
		local ok2, foundName = pcall(function()
			return Players:GetNameFromUserIdAsync(foundId)
		end)
		if ok2 and foundName and not alreadyFound[foundName] then
			table.insert(results, {
				Name        = foundName,
				DisplayName = foundName,
				UserId      = foundId,
				InServer    = false,
				HP=0, WalkSpeed=0
			})
		end
	end

	return {success=true, results=results, query=query}
end
AdminQuery.OnServerInvoke = function(player, queryType)
	local ok, res = pcall(function()
		if queryType == "isAdmin" then
			return {isAdmin=isAdmin(player), isOwner=isOwner(player), success=true}
		elseif queryType == "getPlayers" then
			local list={}
			for _,p in ipairs(Players:GetPlayers()) do
				local h = getHum(p)
				list[#list+1]={
					Name=p.Name, DisplayName=p.DisplayName, UserId=p.UserId,
					isAdmin=isAdmin(p),
					HP=h and math.floor(h.Health) or 0,
					MaxHP=h and math.floor(h.MaxHealth) or 0,
					WalkSpeed=h and math.floor(h.WalkSpeed) or 0,
					Ping=0,
					isFrozen=Frozen[p.UserId] or false,
					isGod=GodMode[p.UserId] or false,
					isMuted=Muted[p.UserId] or false,
					isJailed=Jailed[p.UserId] or false,
					strikeCount=Strikes[p.UserId] or 0,
					warnCount=Warnings[p.UserId] and #Warnings[p.UserId] or 0,
				}
			end
			return {success=true, players=list}
		end
		return {success=false}
	end)
	if ok then return res end
	warn("[PhantomAdmin] Query error: "..tostring(res))
	return {isAdmin=false, success=false}
end


end

Commands.speedboost = function(a, n, mult, sec)
	local t = getP(n); if not t then return false,"Player not found" end
	local m = tonumber(mult) or 2; local s = tonumber(sec) or 20
	local h = getHum(t); if not h then return false,"No humanoid" end
	local orig = h.WalkSpeed
	h.WalkSpeed = math.clamp(orig * m, 0, 1000)
	popMsg(t,"⚡ Speed Boost ×"..m.." for "..s.."s",Color3.fromRGB(34,211,238))
	task.delay(s, function() local h2=getHum(t); if h2 then h2.WalkSpeed=orig end end)
	return true,"Speed boost ×"..m.." → "..t.Name
end

Commands.jumpboost = function(a, n, mult, sec)
	local t = getP(n); if not t then return false,"Player not found" end
	local m = tonumber(mult) or 3; local s = tonumber(sec) or 20
	local h = getHum(t); if not h then return false,"No humanoid" end
	local orig = h.JumpPower
	h.JumpPower = math.clamp(orig * m, 0, 1000); h.UseJumpPower = true
	popMsg(t,"🌙 Jump Boost ×"..m.." for "..s.."s",Color3.fromRGB(168,85,247))
	task.delay(s, function() local h2=getHum(t); if h2 then h2.JumpPower=orig; h2.UseJumpPower=true end end)
	return true,"Jump boost ×"..m.." → "..t.Name
end


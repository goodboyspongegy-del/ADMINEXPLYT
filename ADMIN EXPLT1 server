	task.delay(6, function()
		if bb.Parent then
			TweenSvc:Create(bg, TweenInfo.new(0.5), {BackgroundTransparency=1}):Play()
			TweenSvc:Create(lbl, TweenInfo.new(0.5), {TextTransparency=1}):Play()
		end

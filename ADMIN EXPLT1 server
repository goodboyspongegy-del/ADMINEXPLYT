-- Logs
Commands.getlog = function(a, count)
	local n = math.min(tonumber(count) or 20, #ActionLog)
	local lines = {}
	for i=1,n do
		local e=ActionLog[i]
		if e then lines[#lines+1]="["..e.time.."] "..e.admin.." → "..e.action..(e.target~="—" and " ("..e.target..")" or "") end
	end
	notify(a, "Last "..n.." actions:\n"..table.concat(lines,"\n"), "info")
	return true,"Log sent"
end


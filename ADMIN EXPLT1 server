end

Commands.tempgod = function(a, n, sec)
	local t = getP(n); if not t then return false,"Player not found" end
	local s = tonumber(sec) or 30
	GodMode[t.UserId]=true; local h=getHum(t); if h then h.MaxHealth=math.huge; h.Health=math.huge end
	popMsg(t,"✨ Temporary God Mode ("..s.."s)",Color3.fromRGB(251,191,36))
	task.delay(s, function()
		GodMode[t.UserId]=nil; local h2=getHum(t); if h2 then h2.MaxHealth=100; h2.Health=math.min(h2.Health,100) end
		popMsg(t,"✨ God Mode expired",Color3.fromRGB(160,165,200))
	end)
	return true,"TempGod "..s.."s: "..t.Name
end

-- ── SPEED / JUMP ──────────────────────────────────────────────────
Commands.speed = function(a, n, v)
	local t = getP(n); if not t then return false,"Player not found" end
	local h = getHum(t); if h then h.WalkSpeed=math.clamp(tonumber(v) or 16,0,1000); return true,"Speed "..t.Name.." → "..tostring(v) end

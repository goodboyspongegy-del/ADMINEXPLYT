	local lbl = Instance.new("TextLabel", bg)
	lbl.Size = UDim2.new(1,-16,1,0); lbl.Position = UDim2.new(0,8,0,0)
	lbl.BackgroundTransparency = 1; lbl.Text = msg
	lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 14
	lbl.TextColor3 = Color3.fromRGB(235,238,255); lbl.TextWrapped = true
	-- Tail
	local tri = Instance.new("Frame", bb)

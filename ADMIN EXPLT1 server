ReportEvent.OnServerEvent:Connect(function(reporter, reportedName, reason, category)
	if not reporter or not reporter.Parent then return end

	-- Validate reported player exists
	local reportedPlayer = Players:FindFirstChild(reportedName)
	local reportedUid = reportedPlayer and reportedPlayer.UserId or 0

	-- Rate limit: max 3 reports per player per session
	local reportCount = 0
	for _,r in ipairs(Reports) do if r.reporterUid==reporter.UserId then reportCount=reportCount+1 end end
	if reportCount >= 5 then
		notify(reporter,"⚠ You have reached the report limit for this session","warning")
		return
	end

	-- Duplicate check: same reporter + reported in last 5 mins
	for _,r in ipairs(Reports) do
		if r.reporterUid==reporter.UserId and r.reportedName==reportedName and tick()-r.rawTime<300 then
			notify(reporter,"⚠ You already reported this player recently","warning")
			return
		end
	end

	reportCounter = reportCounter + 1
	local report = {
		id          = reportCounter,
		reporterName= reporter.Name,
		reporterUid = reporter.UserId,
		reportedName= reportedName or "Unknown",
		reportedUid = reportedUid,
		reason      = (reason or "No reason"):sub(1,200),
		category    = category or "General",
		time        = os.date("%H:%M:%S"),
		rawTime     = tick(),
		status      = "PENDING"
	}
	table.insert(Reports, 1, report)
	if #Reports > 100 then Reports[101]=nil end

	-- Confirm to reporter
	notify(reporter,"✅ Report #"..reportCounter.." submitted. Admins have been notified.","success")

	-- Alert all online admins
	notifyAdmins(
		"📋 NEW REPORT #"..reportCounter.."\n"..reporter.Name.." reported "..reportedName..
		"\nReason: "..(reason or "No reason").."\nCategory: "..(category or "General"),
		"warning"
	)

	-- Fire to all admin clients (for Reports tab live update)
	for _,p in ipairs(Players:GetPlayers()) do
		if isAdmin(p) then
			AdminNotif:FireClient(p, "REPORT_UPDATE", "report_new")
		end
	end

	print("[PhantomAdmin] Report #"..reportCounter.." filed by "..reporter.Name.." against "..reportedName)
end)

-- Report query (for Reports tab to fetch all reports)
ReportQuery.OnServerInvoke = function(player, queryType, data)
	if not isAdmin(player) then return {success=false} end

	if queryType == "getAll" then
		return {success=true, reports=Reports}

	elseif queryType == "dismiss" then
		local rid = data and data.id
		for _,r in ipairs(Reports) do
			if r.id==rid then
				r.status="DISMISSED"
				logAction(player,"DISMISS REPORT #"..rid,r.reportedName)
				-- Notify reporter if online
				local rep=Players:GetPlayerByUserId(r.reporterUid)
				if rep then notify(rep,"Your report #"..rid.." was reviewed by admin","info") end
				return {success=true}
			end
		end
		return {success=false, message="Report not found"}

	elseif queryType == "action" then
		local rid = data and data.id
		local action = data and data.action
		for _,r in ipairs(Reports) do
			if r.id==rid then
				r.status="ACTIONED"
				r.actionTaken = action or "Reviewed"
				logAction(player,"ACT REPORT #"..rid,r.reportedName)
				-- Execute action if specified
				local target=Players:GetPlayerByUserId(r.reportedUid)
				if target and action then
					if action=="kick" then
						target:Kick("🚫 You were reported and an admin took action. Reason: "..r.reason)
					elseif action=="warn" then
						Commands.warn(player, target.Name, "Report #"..rid..": "..r.reason)
					elseif action=="ban" then
						Commands.ban(player, target.Name, "Report #"..rid..": "..r.reason)
					elseif action=="mute" then
						Muted[target.UserId]=true
					end
				end
				-- Notify reporter
				local rep=Players:GetPlayerByUserId(r.reporterUid)
				if rep then notify(rep,"✅ Your report #"..rid.." has been actioned. Action: "..(action or "Reviewed"),"success") end
				return {success=true}
			end
		end
		return {success=false, message="Report not found"}

	elseif queryType == "clear" then
		Reports={}; logAction(player,"CLEAR ALL REPORTS","")
		return {success=true}
	end
	return {success=false}
end


	ActionLog={}; return true,"Log cleared"
end

-- ── REPORT MANAGEMENT (admin side) ────────────────────────────────
Commands.get_reports = function(a, status_filter)
	local result={}
	for _,r in ipairs(Reports) do
		if not status_filter or status_filter=="" or r.status==status_filter then
			table.insert(result, string.format("[#%d %s] %s reported %s: %s | %s",
				r.id, r.status, r.reporterName, r.reportedName, r.reason, r.time))
		end
	end
	if #result==0 then notify(a,"No reports found","info") else
		for i=1,math.min(#result,10) do notify(a,result[i],"info") end
	end
	return true,"Sent "..#result.." report(s)"
end

Commands.dismiss_report = function(a, id)
	local rid = tonumber(id)
	for _,r in ipairs(Reports) do
		if r.id==rid then r.status="DISMISSED"; logAction(a,"DISMISS REPORT #"..rid,r.reportedName); return true,"Report #"..rid.." dismissed" end
	end
	return false,"Report not found: "..tostring(id)
end

Commands.act_report = function(a, id, action)
	local rid = tonumber(id)
	for _,r in ipairs(Reports) do
		if r.id==rid then
			r.status="ACTIONED"
			logAction(a,"ACT REPORT #"..rid.." → "..(action or "?"),r.reportedName)
			-- Notify reporter
			local reporter=Players:GetPlayerByUserId(r.reporterUid)
			if reporter then notify(reporter,"✅ Your report about "..r.reportedName.." has been reviewed. Action taken: "..(action or "Reviewed"),"success")end
			return true,"Report #"..rid.." actioned"
		end
	end
	return false,"Report not found: "..tostring(id)
end

Commands.clear_reports = function(a)
	Reports={}; logAction(a,"CLEAR REPORTS",""); return true,"All reports cleared"
end


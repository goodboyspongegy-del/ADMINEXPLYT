-- ── MUTE / WARN ───────────────────────────────────────────────────
Commands.mute = function(a, n)
	local t = getP(n); if not t then return false,"Player not found" end
	Muted[t.UserId]=true
	popMsg(t,"🔇 You have been muted by admin",Color3.fromRGB(251,191,36))
	logAction(a,"MUTE",t.Name)
	return true,"Muted: "..t.Name
end

Commands.unmute = function(a, n)
	local t = getP(n); if not t then return false,"Player not found" end
	Muted[t.UserId]=nil
	popMsg(t,"🔊 You have been unmuted",Color3.fromRGB(16,230,120))
	return true,"Unmuted: "..t.Name
end

Commands.warn = function(a, n, r)
	local t = getP(n); if not t then return false,"Player not found" end
	Warnings[t.UserId] = Warnings[t.UserId] or {}
	local reason = r or "No reason given"
	table.insert(Warnings[t.UserId], reason)
	local count = #Warnings[t.UserId]
	popMsg(t,"⚠ WARNING "..count..": "..reason,Color3.fromRGB(251,191,36))
	notify(a,"⚠ Warned "..t.Name.." ("..count.." total)","warning")
	logAction(a,"WARN ("..count..")",t.Name)
	if count >= 3 then
		announce("⚠ "..t.Name.." has reached "..count.." warnings!",Color3.fromRGB(251,191,36),6)
		notifyAdmins("⚠ "..t.Name.." has "..count.." warnings — consider action","warning")
	end
	return true,"Warned "..t.Name.." ("..count..")"
end

Commands.warnings = function(a, n)
	local t = getP(n); if not t then return false,"Player not found" end
	local w = Warnings[t.UserId] or {}
	local msg = t.Name.." has "..#w.." warning(s)"
	if #w > 0 then
		for i,r in ipairs(w) do msg = msg.."\n  "..i..". "..r end
	end
	notify(a, msg, "info")
	return true, msg
end

Commands.clearwarnings = function(a, n)
	local t = getP(n); if not t then return false,"Player not found" end
	Warnings[t.UserId] = nil
	notify(a,"Warnings cleared for "..t.Name,"success")
	return true,"Warnings cleared: "..t.Name
end

Commands.addstrike = function(a, n)
	local t = getP(n); if not t then return false,"Player not found" end
	Strikes[t.UserId] = (Strikes[t.UserId] or 0) + 1
	local s = Strikes[t.UserId]
	popMsg(t,"❌ STRIKE "..s.."/3 — Final warning",Color3.fromRGB(239,68,68))
	logAction(a,"STRIKE "..s,t.Name)
	if s >= 3 then
		Banned[t.UserId]=true
		t:Kick("☠ 3 strikes — You are banned. Contact admins to appeal.")
		announce("☠ "..t.Name.." received 3 strikes and was banned!",Color3.fromRGB(239,68,68),8)
		logAction(a,"AUTO-BAN (3 strikes)",t.Name)
	end
	return true,"Strike "..s.."/3: "..t.Name
end

Commands.clearstrike = function(a, n)
	local t = getP(n); if not t then return false,"Player not found" end
	Strikes[t.UserId] = nil
	return true,"Strikes cleared: "..t.Name
end

-- ── VISIBILITY ────────────────────────────────────────────────────
Commands.invisible = function(a, n)
	local t = getP(n); if not t then return false,"Player not found" end
	Invisible[t.UserId]=true
	local c = t.Character; if not c then return true,"Will apply on respawn" end
	for _, p in ipairs(c:GetDescendants()) do
		if p:IsA("BasePart") then p.Transparency=1
		elseif p:IsA("Decal") or p:IsA("Texture") then p.Transparency=1 end
	end
	return true,"Invisible: "..t.Name
end

Commands.visible = function(a, n)
	local t = getP(n); if not t then return false,"Player not found" end
	Invisible[t.UserId]=nil
	local c = t.Character; if not c then return true,"Will apply on respawn" end
	for _, p in ipairs(c:GetDescendants()) do
		if p:IsA("BasePart") and p.Name~="HumanoidRootPart" then p.Transparency=0
		elseif p:IsA("Decal") or p:IsA("Texture") then p.Transparency=0 end
	end
	return true,"Visible: "..t.Name
end

Commands.invisible_me = function(a)
	Invisible[a.UserId]=true
	local c=a.Character; if c then for _,p in ipairs(c:GetDescendants())do if p:IsA("BasePart")then p.Transparency=1 end end end
	notify(a,"👻 Invisible ON","success"); return true,"Invisible: you"
end

Commands.visible_me = function(a)
	Invisible[a.UserId]=nil
	local c=a.Character; if c then for _,p in ipairs(c:GetDescendants())do if p:IsA("BasePart")and p.Name~="HumanoidRootPart" then p.Transparency=0 end end end
	return true,"Visible: you"
end

Commands.visibleall = function(a)
	for _, p in ipairs(Players:GetPlayers()) do
		Invisible[p.UserId]=nil
		local c=p.Character; if c then for _,pt in ipairs(c:GetDescendants())do if pt:IsA("BasePart")and pt.Name~="HumanoidRootPart" then pt.Transparency=0 end end end
	end
	return true,"All visible!"
end


-- ── HEALTH ────────────────────────────────────────────────────────
Commands.kill = function(a, n)
	local t = getP(n); if not t then return false,"Player not found" end
	if GodMode[t.UserId] then return false,t.Name.." is in god mode" end
	local h = getHum(t); if h then h.Health=0; logAction(a,"KILL",t.Name); return true,"Killed "..t.Name end
	return false,"No humanoid"
end

Commands.heal = function(a, n)
	local t = getP(n); if not t then return false,"Player not found" end
	local h = getHum(t); if h then h.Health=h.MaxHealth; return true,"Healed "..t.Name end
	return false,"No humanoid"
end

Commands.heal50 = function(a, n)
	local t = getP(n); if not t then return false,"Player not found" end
	local h = getHum(t); if h then h.Health=math.min(h.MaxHealth,h.Health+50); return true,"Healed 50hp: "..t.Name end
	return false,"No humanoid"
end

Commands.damage = function(a, n, v)
	local t = getP(n); if not t then return false,"Player not found" end
	if GodMode[t.UserId] then return false,t.Name.." is god mode" end
	local h = getHum(t); local dmg = tonumber(v) or 50
	if h then h.Health=math.max(0,h.Health-dmg); return true,"Dealt "..dmg.."dmg to "..t.Name end
	return false,"No humanoid"
end

Commands.maxhealth = function(a, n, v)
	local t = getP(n); if not t then return false,"Player not found" end
	local h = getHum(t); local hp = tonumber(v) or 200
	if h then h.MaxHealth=hp; h.Health=hp; return true,"MaxHP "..hp.." → "..t.Name end
	return false,"No humanoid"
end

Commands.sethp = function(a, n, v)
	local t = getP(n); if not t then return false,"Player not found" end
	local h = getHum(t); if h then h.Health=math.clamp(tonumber(v) or 100,0,h.MaxHealth); return true,"HP set: "..t.Name end
	return false,"No humanoid"
end

Commands.armor = function(a, n)
	local t = getP(n); if not t then return false,"Player not found" end
	local h = getHum(t); if h then h.MaxHealth=300; h.Health=300; return true,"Armor (300hp): "..t.Name end
	return false,"No humanoid"
end

Commands.killall = function(a)
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= a and not GodMode[p.UserId] and not Protected[p.UserId] then
			local h = getHum(p); if h then h.Health=0 end
		end
	end
	logAction(a,"KILLALL","everyone")
	return true,"Killed all!"
end

Commands.healall = function(a)
	for _, p in ipairs(Players:GetPlayers()) do
		local h = getHum(p); if h then h.Health=h.MaxHealth end
	end
	return true,"Healed all!"
end

Commands.respawn = function(a, n)
	local t = getP(n); if not t then return false,"Player not found" end
	t:LoadCharacter(); return true,"Respawned "..t.Name
end

Commands.respawnall = function(a)
	for _, p in ipairs(Players:GetPlayers()) do p:LoadCharacter() end
	return true,"Respawned all!"
end

Commands.refresh = function(a, n)
	local t = getP(n); if not t then return false,"Player not found" end
	if t.Character then
		local pos = t.Character:GetPrimaryPartCFrame()
		t:LoadCharacter()
		task.delay(1.2, function()
			if t.Character then
				pcall(function() t.Character:SetPrimaryPartCFrame(pos) end)
			end
		end)
	end
	return true,"Refreshed "..t.Name
end

Commands.revive = function(a, n)
	local t = getP(n); if not t then return false,"Player not found" end
	local pos = getHRP(t) and getHRP(t).CFrame or CFrame.new(0,5,0)
	t:LoadCharacter()
	task.delay(1.3, function()
		local h = getHRP(t); if h then h.CFrame = pos end
		local hm = getHum(t); if hm then hm.Health = hm.MaxHealth end
	end)
	return true,"Revived "..t.Name
end

Commands.healovertime = function(a, n, total, dur)
	local t = getP(n); if not t then return false,"Player not found" end
	local amount = tonumber(total) or 100
	local duration = tonumber(dur) or 10
	local perTick = amount / (duration / 0.5)
	task.spawn(function()
		local elapsed = 0
		while elapsed < duration do
			task.wait(0.5); elapsed = elapsed + 0.5
			local h = getHum(t); if not h then break end
			h.Health = math.min(h.MaxHealth, h.Health + perTick)
		end
	end)
	popMsg(t,"💚 Healing over "..duration.."s ("..amount.."hp)",Color3.fromRGB(16,230,120))
	return true,"Heal over time: "..t.Name
end

-- ── GOD MODE ──────────────────────────────────────────────────────
Commands.god = function(a, n)
	local t = getP(n); if not t then return false,"Player not found" end
	local h = getHum(t)
	if h then h.MaxHealth=math.huge; h.Health=math.huge; GodMode[t.UserId]=true; logAction(a,"GOD",t.Name); return true,"God mode ON: "..t.Name end
	return false,"No humanoid"
end

Commands.ungod = function(a, n)
	local t = getP(n); if not t then return false,"Player not found" end

-- Private notification bubble above player's head (visible to everyone)
local function popMsg(p, msg, col)
	if not p then return end
	local hrp = getHRP(p)
	if not hrp then notify(p, msg, "info"); return end
	-- Remove old bubble
	local old = hrp:FindFirstChild("PA_PopBubble"); if old then old:Destroy() end
	col = col or Color3.fromRGB(99,102,241)
	local bb = Instance.new("BillboardGui", hrp)
	bb.Name      = "PA_PopBubble"
	bb.StudsOffset = Vector3.new(0, 6, 0)
	bb.MaxDistance = 80
	bb.AlwaysOnTop = false
	bb.Size      = UDim2.new(0, math.clamp(#msg * 7 + 40, 100, 500), 0, 46)
	Debris:AddItem(bb, 7)
	local bg = Instance.new("Frame", bb)
	bg.Size = UDim2.new(1,0,0,38)
	bg.BackgroundColor3 = Color3.fromRGB(10,10,24)

-- ── KICK / BAN ────────────────────────────────────────────────────
Commands.kick = function(a, n, r)
	local t = getP(n); if not t then return false,"Player not found" end
	if Protected[t.UserId] and not isOwner(a) then return false,"That player is protected" end
	t:Kick("🚫 Kicked by "..a.Name..". Reason: "..(r or "No reason given"))
	logAction(a,"KICK",t.Name)
	return true,"Kicked "..t.Name
end

Commands.ban = function(a, n, r)
	local t = getP(n); if not t then return false,"Player not found" end
	if Protected[t.UserId] and not isOwner(a) then return false,"That player is protected" end
	Banned[t.UserId] = true
	t:Kick("☠ Permanently banned by "..a.Name..". Reason: "..(r or "No reason given"))
	logAction(a,"BAN",t.Name)
	return true,"Banned "..t.Name
end

Commands.unban = function(a, n)
	local t = getP(n)
	if t then Banned[t.UserId] = nil; logAction(a,"UNBAN",t.Name) end
	return true,"Unbanned "..(n or "?")
end

Commands.tempban = function(a, n, sec, r)
	local t = getP(n); if not t then return false,"Player not found" end
	if Protected[t.UserId] and not isOwner(a) then return false,"That player is protected" end
	local s = tonumber(sec) or 300
	Banned[t.UserId] = {expiry = tick() + s, reason = r or "Temp ban"}
	t:Kick("⏱ Temp banned for "..s.."s. Reason: "..(r or "No reason"))
	task.delay(s, function() if type(Banned[t.UserId])=="table" then Banned[t.UserId]=nil end end)
	logAction(a,"TEMPBAN "..s.."s",t.Name)
	return true,"Temp banned "..t.Name.." for "..s.."s"
end


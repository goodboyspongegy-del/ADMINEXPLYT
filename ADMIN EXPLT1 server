end

-- Light tween
local function tweenLight(props, t)
	if litTween and litTween.PlaybackState ~= Enum.PlaybackState.Completed then litTween:Cancel() end
	litTween = TweenSvc:Create(Lighting, TweenInfo.new(t or 2, Enum.EasingStyle.Sine), props)
	litTween:Play()
end

local function resetLighting()
	tweenLight({
		ClockTime     = origLight.ClockTime,
		Brightness    = origLight.Brightness,
		Ambient       = origLight.Ambient,
		FogEnd        = origLight.FogEnd,
		FogStart      = origLight.FogStart,
		OutdoorAmbient= origLight.OutdoorAmbient,
	}, 4)
	task.delay(4.1, function()
		Lighting.FogColor = origLight.FogColor
	end)
end

-- Scale helper
local function setScale(p, s)
	local h = getHum(p); if not h then return end
	for _, n in ipairs({"BodyDepthScale","BodyHeightScale","BodyWidthScale","HeadScale"}) do
		local v = h:FindFirstChild(n); if v then v.Value = s end
	end
end

-- Scale specific axes
local function setScaleAxes(p, dv, hv, wv, hd)
	local h = getHum(p); if not h then return end
	local function sv(n,val) local v=h:FindFirstChild(n); if v and val then v.Value=val end end
	sv("BodyDepthScale",dv); sv("BodyHeightScale",hv); sv("BodyWidthScale",wv); sv("HeadScale",hd)
end

-- Clear all visual effects
local function clearFX(p)
	local c = p and p.Character; if not c then return end
	for _, d in ipairs(c:GetDescendants()) do
		if d:IsA("Fire") or d:IsA("Smoke") or d:IsA("Sparkles")
		or d:IsA("ParticleEmitter") or d:IsA("Trail")
		or d:IsA("PointLight") or d:IsA("SpotLight") or d:IsA("SurfaceLight") then
			d:Destroy()
		end
	end
	-- Also remove any BillboardGui effects
	for _, d in ipairs(c:GetDescendants()) do
		if d:IsA("BillboardGui") and d.Name:find("PA_") then d:Destroy() end
	end
end

-- Apply FX to torso/HRP
local function fxOn(p, fxClass, props, dur)
	local c = p and p.Character; if not c then return end
	local root = c:FindFirstChild("Torso") or c:FindFirstChild("UpperTorso") or c:FindFirstChild("HumanoidRootPart")
	if not root then return end
	-- Remove existing same type
	for _, ch in ipairs(root:GetChildren()) do
		if ch:IsA(fxClass) and ch.Name == "PA_"..fxClass then ch:Destroy() end
	end
	local fx = Instance.new(fxClass, root); fx.Name = "PA_"..fxClass
	for k, v in pairs(props or {}) do pcall(function() fx[k] = v end) end
	if dur then Debris:AddItem(fx, dur) end
	return fx
end


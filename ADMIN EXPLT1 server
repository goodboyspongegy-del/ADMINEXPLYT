local function runMeteorEvent(duration)
	local evtName = "MeteorShower"
	if activeEvts[evtName] then return end
	activeEvts[evtName] = true
	EventUpdate:FireAllClients("INTRO",{message="☄ METEOR SHOWER INCOMING — TAKE COVER!"})
	EventUpdate:FireAllClients("START",{name=evtName,duration=duration,icon="rbxassetid://15909632816"})
	local s = mkSnd("rbxassetid://1840422987")

	tweenLight({Brightness=0.6, Ambient=Color3.fromRGB(80,40,0), ClockTime=0},3)

	-- Spawn region check
	local spawnRegion = WS:FindFirstChild("MeteorSpawnRegion")
	local minX, maxX, minZ, maxZ, spawnY = -150, 150, -150, 150, 150
	if spawnRegion and spawnRegion:IsA("BasePart") then
		local sz=spawnRegion.Size; local pos=spawnRegion.Position
		minX=pos.X-sz.X/2; maxX=pos.X+sz.X/2
		minZ=pos.Z-sz.Z/2; maxZ=pos.Z+sz.Z/2
		spawnY=pos.Y+sz.Y/2+20
	end

	local meteorFolder = Instance.new("Folder", WS); meteorFolder.Name = "PA_MeteorShower"
	local mConn; local mLast = tick()
	-- Interval gets faster as event progresses
	local startInterval = 0.6
	local endInterval   = 0.08

	mConn = RunSvc.Heartbeat:Connect(function()
		if not activeEvts[evtName] then mConn:Disconnect(); return end
		local progress = math.clamp((tick() - (tick() - duration)) / duration, 0, 1)
		local interval = startInterval - (startInterval - endInterval) * progress

		if tick() - mLast >= interval then
			mLast = tick()

			-- Create meteor
			local size = math.random(2, 6) * 0.5 + 1
			local m = Instance.new("Part", meteorFolder)
			m.Name = "Meteor"
			m.Size = Vector3.new(size, size, size)
			m.Shape = Enum.PartType.Ball
			m.Material = Enum.Material.Rock
			m.BrickColor = BrickColor.new("Dark orange")
			m.CastShadow = false

			-- Random spawn position
			local spawnX = math.random(minX, maxX)
			local spawnZ = math.random(minZ, maxZ)
			m.CFrame = CFrame.new(spawnX, spawnY + math.random(0,30), spawnZ)

			-- Velocity: angled fall
			local angle = math.random(-25, 25)
			m.AssemblyLinearVelocity = Vector3.new(
				math.random(-20,20), -90 + math.random(-15, 15), math.random(-20,20)
			)

			-- Spin while falling
			local spinBav = Instance.new("BodyAngularVelocity", m)
			spinBav.AngularVelocity = Vector3.new(math.random(-8,8), math.random(-5,5), math.random(-8,8))
			spinBav.MaxTorque = Vector3.new(1e5,1e5,1e5)

			-- Glowing fire trail
			local a0 = Instance.new("Attachment", m); a0.Position = Vector3.new(0,0,0)
			local a1 = Instance.new("Attachment", m); a1.Position = Vector3.new(0, size*0.6, 0)
			local trail = Instance.new("Trail", m)
			trail.Attachment0=a0; trail.Attachment1=a1
			trail.Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0, Color3.fromRGB(255,200,50)),
				ColorSequenceKeypoint.new(0.4, Color3.fromRGB(255,80,0)),
				ColorSequenceKeypoint.new(1, Color3.fromRGB(80,20,0)),
			})
			trail.Transparency = NumberSequence.new(0, 0.8)
			trail.Lifetime = 0.7
			trail.MinLength = 0

			-- Glow on meteor
			local pl = Instance.new("PointLight", m)
			pl.Brightness = 6; pl.Range = 20
			pl.Color = Color3.fromRGB(255,150,50)

			-- Smoke puff
			local smk = Instance.new("Smoke", m)
			smk.Color = Color3.fromRGB(80,60,50); smk.RiseVelocity = 5; smk.Opacity = 0.3

			-- Impact logic
			local impacted = false
			m.Touched:Connect(function(hit)
				if impacted then return end
				if not m.Parent then return end
				-- Don't trigger on other meteors
				if hit:IsA("Part") and hit.Parent == meteorFolder then return end

				impacted = true

				local impactPos = m.Position

				-- Damage nearby players
				for _, p in ipairs(Players:GetPlayers()) do
					local hrp = getHRP(p)
					if hrp then
						local dist = (hrp.Position - impactPos).Magnitude
						if dist < 15 then
							local dmg = math.floor(50 * (1 - dist/15))
							local h = getHum(p)
							if h and not GodMode[p.UserId] then h:TakeDamage(dmg) end
						end
					end
				end

				-- Explosion effect
				local exp = Instance.new("Explosion", WS)
				exp.Position = impactPos
				exp.BlastRadius = size * 3.5
				exp.BlastPressure = 300000
				exp.DestroyJointRadiusPercent = 0

				-- Crater: scorch mark on floor
				local crater = Instance.new("Part", WS)
				crater.Size = Vector3.new(size*3, 0.3, size*3)
				crater.Shape = Enum.PartType.Cylinder
				crater.Anchored = true; crater.CanCollide = false; crater.CastShadow = false
				crater.BrickColor = BrickColor.new("Really black")
				crater.Material = Enum.Material.SmoothPlastic
				crater.CFrame = CFrame.new(impactPos.X, impactPos.Y-size/2+0.2, impactPos.Z)
					* CFrame.Angles(0,0,math.pi/2)
				crater.Transparency = 0.1
				Debris:AddItem(crater, 60)

				-- Debris chunks flying out
				for i = 1, math.random(4,8) do
					local chunk = Instance.new("Part", WS)
					chunk.Size = Vector3.new(math.random(1,3)*0.3, math.random(1,3)*0.3, math.random(1,3)*0.3)
					chunk.Material = Enum.Material.Rock
					chunk.BrickColor = BrickColor.new("Dark orange")
					chunk.CFrame = CFrame.new(impactPos)
					chunk.AssemblyLinearVelocity = Vector3.new(
						math.random(-30,30), math.random(15,40), math.random(-30,30)
					)
					Debris:AddItem(chunk, 8)
				end

				m:Destroy()
			end)
			Debris:AddItem(m, 12)
		end
	end)

	task.delay(duration, function()
		mConn:Disconnect()
		for _,c in ipairs(meteorFolder:GetChildren()) do c:Destroy() end
		meteorFolder:Destroy()
		evStop(evtName, s, nil)
	end)
end


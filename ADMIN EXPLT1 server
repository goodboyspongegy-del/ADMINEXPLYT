	end
	return true,"God all!"
end

Commands.ungodall = function(a)
	for _, p in ipairs(Players:GetPlayers()) do
		GodMode[p.UserId]=nil; local h=getHum(p); if h then h.MaxHealth=100; h.Health=math.min(h.Health,100) end
	end
	return true,"Ungod all!"
end

Commands.god_me = function(a)
	GodMode[a.UserId]=true; local h=getHum(a); if h then h.MaxHealth=math.huge; h.Health=math.huge end
	notify(a,"✨ God mode ON!","success"); return true,"God: you"
end

Commands.ungod_me = function(a)
	GodMode[a.UserId]=nil; local h=getHum(a); if h then h.MaxHealth=100; h.Health=math.min(h.Health,100) end

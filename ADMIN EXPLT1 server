local EventModels = RS:FindFirstChild("Event") -- optional folder for Taco/DJ/Barrier/Blackhole models

local function evStop(name, sound, cleanup)
	if not activeEvts[name] then return end
	pcall(function() if cleanup then cleanup() end end)
	if sound and sound.Parent then pcall(function() sound:Stop(); sound:Destroy() end) end
	local anyOther=false
	for n,v in pairs(activeEvts) do if n~=name and v then anyOther=true;break end end
	if not anyOther then resetLighting() end
	EventUpdate:FireAllClients("STOP",{name=name})
	activeEvts[name]=nil
	local endSnd=Instance.new("Sound",WS);endSnd.SoundId="rbxassetid://2048662066";endSnd.Volume=8;endSnd:Play()
	Debris:AddItem(endSnd,5)
end

local function mkSnd(id, loop, vol)
	if not id or id=="" then return nil end
	local s=Instance.new("Sound",WS)
	s.SoundId=id; s.Looped=loop~=false; s.Volume=vol or 1
	s.RollOffMaxDistance=10000
	pcall(function() s:Play() end)
	return s
end

-- ── SCRIPTED FLOOD EVENT (real rising water part) ─────────────────
local function runFloodEvent(duration)
	local evtName = "Flood"
	if activeEvts[evtName] then return end
	activeEvts[evtName] = true
	EventUpdate:FireAllClients("INTRO",{message="🌊 THE FLOOD IS RISING!"})
	EventUpdate:FireAllClients("START",{name=evtName,duration=duration,icon="rbxassetid://14293766276"})
	local s = mkSnd("rbxassetid://9114492495")

	-- Create water part at ground level
	local water = Instance.new("Part", WS)
	water.Name = "PA_FloodWater"
	water.Size = Vector3.new(4000, 1, 4000)
	water.Position = Vector3.new(0, -50, 0)  -- start below ground
	water.Anchored = true
	water.CanCollide = true
	water.Material = Enum.Material.Water
	water.BrickColor = BrickColor.new("Cyan")
	water.Transparency = 0.35
	water.TopSurface = Enum.SurfaceType.Smooth
	water.BottomSurface = Enum.SurfaceType.Smooth
	water.CastShadow = false

	-- Fog for atmosphere
	local origFogEnd2 = Lighting.FogEnd
	Lighting.FogEnd = 300
	Lighting.FogColor = Color3.fromRGB(30, 90, 150)
	tweenLight({Brightness=0.8, Ambient=Color3.fromRGB(20,60,120), ClockTime=8},3)

	-- Rise up over time
	local targetY = 35  -- how high water rises
	local riseTime = 20 -- seconds to reach peak
	local stayTime = duration - riseTime - 10
	local fallTime = 10

	-- Rise phase
	TweenSvc:Create(water, TweenInfo.new(riseTime, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
		{Position=Vector3.new(0, targetY, 0)}):Play()

	-- Wave effect (runs while event is active)
	local waveConn; local waveTime=0
	waveConn = RunSvc.Heartbeat:Connect(function(dt)
		waveTime = waveTime + dt
		if not activeEvts[evtName] then waveConn:Disconnect(); return end
		if water.Parent then
			water.Size = Vector3.new(4000, 1 + math.sin(waveTime*1.5)*0.8, 4000)
		end
	end)

	-- Damage players underwater
	local dmgConn; dmgConn = RunSvc.Heartbeat:Connect(function()
		if not activeEvts[evtName] then dmgConn:Disconnect(); return end
		for _,p in ipairs(Players:GetPlayers()) do
			local hrp = getHRP(p)
			if hrp and hrp.Position.Y < water.Position.Y + 2 then
				local h = getHum(p)
				if h and not GodMode[p.UserId] then h:TakeDamage(3) end
			end
		end
	end)

	-- After duration: drain water
	task.delay(duration - fallTime, function()
		if not water.Parent then return end
		TweenSvc:Create(water, TweenInfo.new(fallTime, Enum.EasingStyle.Sine),
			{Position=Vector3.new(0,-60,0)}):Play()
	end)

	task.delay(duration, function()
		waveConn:Disconnect(); dmgConn:Disconnect()
		evStop(evtName, s, function()
			if water.Parent then water:Destroy() end
			Lighting.FogEnd = origFogEnd2
			Lighting.FogColor = origLight.FogColor
		end)
	end)
end


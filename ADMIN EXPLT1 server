local function isAdmin(p)
	if not p then return false end
	if AdminRanks[p.UserId] then return true end
	for _, id in ipairs(ADMIN_IDS) do if p.UserId == id then return true end end
	if p.UserId == game.CreatorId then return true end
	return false
end

local function isOwner(p)
	if not p then return false end
	for _, id in ipairs(ADMIN_IDS) do if p.UserId == id then return true end end
	return p.UserId == game.CreatorId
end

-- Find player by partial name match (prioritises exact, then starts-with, then contains)
local function getP(name)
	if not name or name == "" then return nil end
	local lo = name:lower()
	local exact, starts, contains
	for _, p in ipairs(Players:GetPlayers()) do
		local pn = p.Name:lower()
		local dn = p.DisplayName:lower()
		if pn == lo or dn == lo then
			return p -- instant exact match
		elseif not starts and (pn:sub(1,#lo)==lo or dn:sub(1,#lo)==lo) then
			starts = p
		elseif not contains and (pn:find(lo,1,true) or dn:find(lo,1,true)) then
			contains = p
		end
	end
	return starts or contains
end


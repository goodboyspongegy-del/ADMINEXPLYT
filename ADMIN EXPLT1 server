local function sendBubble(p, msg, colorName, fontSize, duration, adminName)
	if not p then return end
	local hrp = getHRP(p); if not hrp then return end
	msg = tostring(msg or "..."): sub(1, 200) -- cap length
	local col   = BubbleColors[colorName] or BubbleColors.white
	fontSize    = math.clamp(tonumber(fontSize) or 14, 10, 24)
	duration    = math.clamp(tonumber(duration)  or 8,  2, 30)

	-- Remove old bubble from this player
	local old = hrp:FindFirstChild("PA_Bubble"); if old then old:Destroy() end

	local W = math.clamp(#msg * (fontSize * 0.62) + 60, 140, 520)
	local H = 50 + (math.ceil(#msg * fontSize * 0.62 / W) * (fontSize + 4))
	H = math.clamp(H, 50, 160)

	local bb = Instance.new("BillboardGui", hrp)
	bb.Name        = "PA_Bubble"
	bb.StudsOffset = Vector3.new(0, 8, 0)
	bb.Size        = UDim2.new(0, W, 0, H)
	bb.MaxDistance = 100
	bb.AlwaysOnTop = false
	Debris:AddItem(bb, duration + 1)

	-- Main bubble frame
	local bg = Instance.new("Frame", bb)
	bg.Size              = UDim2.new(1,0,0,H-8)
	bg.BackgroundColor3  = Color3.fromRGB(12,12,28)
	bg.BackgroundTransparency = 0.05
	bg.BorderSizePixel   = 0
	local bgc = Instance.new("UICorner",bg); bgc.CornerRadius = UDim.new(0,16)
	local bgs = Instance.new("UIStroke",bg); bgs.Color = col; bgs.Thickness = 2

	-- Optional admin badge at top
	if adminName then
		local badge = Instance.new("TextLabel", bg)
		badge.Size = UDim2.new(1,-12,0,14); badge.Position = UDim2.new(0,6,0,4)
		badge.BackgroundTransparency = 1; badge.Text = "⚡ "..adminName.." (Admin)"
		badge.Font = Enum.Font.GothamBold; badge.TextSize = 9
		badge.TextColor3 = col; badge.TextXAlignment = Enum.TextXAlignment.Left
	end

	-- Message text
	local lbl = Instance.new("TextLabel", bg)
	lbl.Size     = UDim2.new(1,-16,1,-(adminName and 16 or 4))
	lbl.Position = UDim2.new(0,8,0,adminName and 16 or 2)
	lbl.BackgroundTransparency = 1
	lbl.Text     = msg
	lbl.Font     = Enum.Font.GothamBold
	lbl.TextSize = fontSize
	lbl.TextColor3 = Color3.fromRGB(235,238,255)
	lbl.TextWrapped = true
	lbl.TextXAlignment = Enum.TextXAlignment.Left

	-- Tail triangle
	local tail = Instance.new("Frame", bb)
	tail.Size = UDim2.new(0,14,0,12); tail.Position = UDim2.new(0.12,0,0,H-20)
	tail.BackgroundColor3 = Color3.fromRGB(12,12,28)
	tail.Rotation = 45; tail.BorderSizePixel = 0
	Instance.new("UICorner",tail).CornerRadius = UDim.new(0,2)

	-- Left color accent
	local accent = Instance.new("Frame", bg)
	accent.Size = UDim2.new(0,4,0.7,0); accent.Position = UDim2.new(0,0,0.15,0)
	accent.BackgroundColor3 = col; accent.BorderSizePixel = 0
	Instance.new("UICorner",accent).CornerRadius = UDim.new(0,2)

	-- Pop-in animation
	bb.Size = UDim2.new(0,0,0,0)
	TweenSvc:Create(bb, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
		{Size=UDim2.new(0,W,0,H)}):Play()

	-- Fade out near end
	task.delay(duration - 1, function()
		if bb.Parent then
			TweenSvc:Create(bg, TweenInfo.new(0.8), {BackgroundTransparency=1}):Play()
			TweenSvc:Create(lbl, TweenInfo.new(0.8), {TextTransparency=1}):Play()
			TweenSvc:Create(bb,  TweenInfo.new(0.8), {Size=UDim2.new(0,W*0.9,0,H*0.9)}):Play()
		end
	end)
end


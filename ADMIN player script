local function switchTab(name)
	if activeTabName == name then return end
	activeTabName = name
	for n, pg in pairs(pages) do
		pg.Visible = (n == name)
	end
	for n, btn in pairs(sideBtns) do
		local col = btn._col
		local active = (n == name)
		tween(btn, {
			BackgroundColor3 = active
				and Color3.new(col.R*.18,col.G*.18,col.B*.18)
				or  Color3.new(0,0,0),
			TextColor3 = active and col or C.T3,
		}, .15)
		local bar = btn:FindFirstChild("Bar")
		if bar then
			tween(bar, {BackgroundColor3 = active and col or Color3.new(0,0,0)}, .15)
		end
	end
end


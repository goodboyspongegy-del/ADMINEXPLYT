local function showAcDropdown(box, matches, onPick)
	for _, c in ipairs(AcList:GetChildren()) do
		if c:IsA("Frame") then c:Destroy() end
	end
	if #matches == 0 then hideAc(); return end

	local ap = box.AbsolutePosition
	local pp = Panel.AbsolutePosition
	local W  = math.max(box.AbsoluteSize.X, 260)

	AcDrop.Position = UDim2.new(0, ap.X-pp.X, 0, ap.Y-pp.Y+box.AbsoluteSize.Y+4)
	AcDrop.Visible  = true

	for i, p in ipairs(matches) do
		if i > 8 then break end
		local row = Frame(AcList, {
			Size = UDim2.new(1,0,0,38),
			BackgroundColor3 = C.BG2,
			ZIndex = 282,
		})
		Corner(row, 6)
		Hover(row, C.BG2, C.BG3)

		local av = Instance.new("ImageLabel", row)
		av.Size = UDim2.new(0,24,0,24)
		av.Position = UDim2.new(0,6,0.5,-12)
		av.BackgroundTransparency=1
		av.Image = "rbxthumb://type=AvatarHeadShot&id="..p.UserId.."&w=48&h=48"
		av.ZIndex = 283
		Corner(av,12)

		Label(row,{Text=p.DisplayName,TextSize=13,Font=Enum.Font.GothamBold,Size=UDim2.new(1,-38,0,18),Position=UDim2.new(0,36,0,3),ZIndex=283})
		Label(row,{Text="@"..p.Name,TextSize=10,Font=Enum.Font.GothamMedium,TextColor3=C.T3,Size=UDim2.new(1,-38,0,13),Position=UDim2.new(0,36,0,21),ZIndex=283})

		local h = p.Character and p.Character:FindFirstChildOfClass("Humanoid")
		if h and h.MaxHealth > 0 then
			local pct = math.clamp(h.Health/h.MaxHealth,0,1)
			local bg = Frame(row,{Size=UDim2.new(0,48,0,4),Position=UDim2.new(1,-54,1,-8),BackgroundColor3=C.BG4,ZIndex=283}); Corner(bg,2)
			local fill = Frame(bg,{Size=UDim2.new(pct,0,1,0),BackgroundColor3=pct>.5 and C.GRN or (pct>.25 and C.YEL or C.RED),ZIndex=284}); Corner(fill,2)
		end

		local click = Button(row,{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=285})
		click.MouseButton1Click:Connect(function()
			hideAc()
			onPick(p)
		end)
	end

	local H = math.min(#matches,8)*42+8
	tweenBack(AcDrop,{Size=UDim2.new(0,W,0,H)},.18)
end

-- Attach autocomplete to a TextBox
local function attachAC(box, onConfirmed, question)
	local deb = false
	box:GetPropertyChangedSignal("Text"):Connect(function()
		if deb then return end
		local term = box.Text:lower()
		if #term < 1 then hideAc(); return end
		local matches = {}
		for _, p in ipairs(Players:GetPlayers()) do
			local pn = p.Name:lower(); local dn = p.DisplayName:lower()
			if pn:find(term,1,true) or dn:find(term,1,true) then
				table.insert(matches, p)
			end
		end
		if #matches == 0 then hideAc(); return end
		showAcDropdown(box, matches, function(p)
			deb = true; box.Text = p.Name; deb = false
			if onConfirmed then
				showConfirm(p, question, function()
					selPlayer = p.Name
					onConfirmed(p.Name)
				end)
			else
				selPlayer = p.Name
				notif("🎯 Target: "..p.DisplayName,"info",2)
			end
		end)
	end)

	box.FocusLost:Connect(function(enter)
		task.delay(.14, function()
			hideAc()
			if enter and box.Text ~= "" then
				local lo = box.Text:lower()
				for _, p in ipairs(Players:GetPlayers()) do
					if p.Name:lower():find(lo,1,true) or p.DisplayName:lower():find(lo,1,true) then
						if onConfirmed then
							showConfirm(p, question, function()
								selPlayer = p.Name
								box.Text  = p.Name
								onConfirmed(p.Name)
							end)
						else
							selPlayer = p.Name
							box.Text  = p.Name
							notif("🎯 Target: "..p.DisplayName,"info",2)
						end
						break
					end
				end
			end
		end)
	end)
end

UIS.InputBegan:Connect(function(inp)
	if inp.UserInputType == Enum.UserInputType.MouseButton1 then
		local mp = inp.Position
		local dp = AcDrop.AbsolutePosition
		local ds = AcDrop.AbsoluteSize
		if not(mp.X>=dp.X and mp.X<=dp.X+ds.X and mp.Y>=dp.Y and mp.Y<=dp.Y+ds.Y) then
			task.delay(.1, hideAc)
		end
	end
	if inp.KeyCode == Enum.KeyCode.Escape then
		hideAc(); closeConfirm()
	end
end)


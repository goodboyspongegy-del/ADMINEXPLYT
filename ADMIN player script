--  TWEEN HELPERS
-- ════════════════════════════════════════════════════════════════
local function tween(obj, props, t, style, dir)
	TS:Create(obj,
		TweenInfo.new(t or .2, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out),
		props):Play()
end
local function tweenBack(obj, props, t)
	TS:Create(obj,
		TweenInfo.new(t or .3, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
		props):Play()
end


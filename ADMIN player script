				if flyConn then flyConn:Disconnect(); flyConn=nil end
				local char=lp.Character
				if char then
					local hrp=char:FindFirstChild("HumanoidRootPart")
					if hrp then
						for _,v in ipairs(hrp:GetChildren()) do
							if v.Name=="PA_FBV" or v.Name=="PA_FBG" then v:Destroy() end
						end
					end
				end
				notif("✈ Fly OFF","info",2)
			else
				flyOn=true
				local char=lp.Character
				if not char then notif("No character","error"); flyOn=false; return end
				local hrp=char:FindFirstChild("HumanoidRootPart")
				if not hrp then flyOn=false; return end
				local bv=Instance.new("BodyVelocity",hrp); bv.Name="PA_FBV"
				bv.MaxForce=Vector3.new(1e9,1e9,1e9); bv.Velocity=Vector3.zero
				local bg=Instance.new("BodyGyro",hrp); bg.Name="PA_FBG"
				bg.MaxTorque=Vector3.new(1e9,1e9,1e9); bg.P=9e3; bg.CFrame=hrp.CFrame
				local cam=WS.CurrentCamera; local spd=65
				flyConn=Run.Heartbeat:Connect(function()
					if not flyOn or not char.Parent then if flyConn then flyConn:Disconnect(); flyConn=nil end; return end
					local d=Vector3.zero
					if UIS:IsKeyDown(Enum.KeyCode.W) then d=d+cam.CFrame.LookVector end
					if UIS:IsKeyDown(Enum.KeyCode.S) then d=d-cam.CFrame.LookVector end
					if UIS:IsKeyDown(Enum.KeyCode.A) then d=d-cam.CFrame.RightVector end
					if UIS:IsKeyDown(Enum.KeyCode.D) then d=d+cam.CFrame.RightVector end
					if UIS:IsKeyDown(Enum.KeyCode.Space) then d=d+Vector3.new(0,1,0) end
					if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then d=d-Vector3.new(0,1,0) end
					bv.Velocity=d*spd; bg.CFrame=cam.CFrame
				end)
				notif("✈ Fly ON — WASD+Space/Shift","success",3)
			end
		end},
	})
end


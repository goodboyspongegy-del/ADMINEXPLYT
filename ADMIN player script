	local colRow=Frame(pg,{Size=UDim2.new(0.54,-3,0,30),Position=UDim2.new(0.46,0,0,26),BackgroundTransparency=1,ZIndex=207})
	ListLayout(colRow,Enum.FillDirection.Horizontal,4)
	local cBtns={}
	for _,bc in ipairs(BCOLS) do
		local cb=Frame(colRow,{Size=UDim2.new(0,24,1,0),BackgroundColor3=bc[2],ZIndex=208})
		Corner(cb,5)
		local cSel=Button(cb,{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=209})
		cBtns[bc[1]]={f=cb,c=bc[2]}
		cSel.MouseButton1Click:Connect(function()
			selCol[1]=bc[1]
			for k,v in pairs(cBtns) do Stroke(v.f,k==bc[1] and Color3.new(1,1,1) or v.c,k==bc[1] and 2.5 or 0) end
		end)
	end

	local msgBox=TextBox(pg,{Size=UDim2.new(1,0,0,48),Position=UDim2.new(0,0,0,64),PlaceholderText="💬 Type your message here...",PlaceholderColor3=C.T3,Text="",BackgroundColor3=C.BG2,TextSize=14,ZIndex=207})
	Corner(msgBox,8); Stroke(msgBox,C.PNK,1.5); Pad(msgBox,0,0,10,0)
	msgBox.Focused:Connect(function() Stroke(msgBox,C.PNK,2) end)
	msgBox.FocusLost:Connect(function() Stroke(msgBox,C.PNK,1.5) end)

	local function doSend(targets)
		local m=msgBox.Text
		if m=="" then notif("⚠ Type a message!","warning"); return end
		local col=selCol[1]
		for _,name in ipairs(targets) do fire("bubblechat",name,m,col,"14","8") end
		notif("💬 Sent to "..#targets.." player(s)!","success",2)
	end
	local function getTargets()
		local n=nameBox.Text
		if n~="" then return{n} end
		local a={}; for _,p in ipairs(Players:GetPlayers()) do a[#a+1]=p.Name end; return a
	end

	-- Quick phrases
	local phrases={"LOL 😂","I am the admin 😈","No escape 😈","BOW DOWN 👑","⚡ A.APK.PANEL","You're done 💀","GG ez 😎","Skill issue 💀","Watch yourself 👁","Get rekt 😂"}

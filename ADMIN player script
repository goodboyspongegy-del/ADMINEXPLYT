		Corner(pb,5); Stroke(pb,C.BORD,1); Hover(pb,C.BG3,C.BG4)
		pb.MouseButton1Click:Connect(function() msgBox.Text=p end)
	end

	local btnRow=Frame(pg,{Size=UDim2.new(1,0,0,36),Position=UDim2.new(0,0,0,188),BackgroundTransparency=1,ZIndex=207})
	ListLayout(btnRow,Enum.FillDirection.Horizontal,8)
	local function mkBtnB(text,col,fn)
		local b=Button(btnRow,{Size=UDim2.new(0,0,1,0),AutomaticSize=Enum.AutomaticSize.X,BackgroundColor3=Color3.new(col.R*.18,col.G*.18,col.B*.18),Text=text,TextSize=13,Font=Enum.Font.GothamBlack,TextColor3=col,ZIndex=208})
		Corner(b,8); Stroke(b,col,1.5); Pad(b,0,0,12,12); Hover(b,Color3.new(col.R*.18,col.G*.18,col.B*.18),Color3.new(col.R*.32,col.G*.32,col.B*.32))
		b.MouseButton1Click:Connect(fn); return b
	end
	mkBtnB("💬 Send",   C.PNK, function() doSend(getTargets()) end)
	mkBtnB("📢 All",    C.CYN, function() local a={};for _,p in ipairs(Players:GetPlayers())do a[#a+1]=p.Name end;doSend(a) end)
	mkBtnB("🔁 Spam×5", C.ORG, function() local t=getTargets();for i=1,5 do task.delay(i*.6,function()doSend(t)end)end end)
	mkBtnB("🧹 Clear",  C.T2,  function() msgBox.Text="" end)
end


-- ════════════════════════════════════════════════════════════════
task.spawn(function()
	local tries = 0
	while not AdminNotif and tries < 60 do task.wait(0.5); tries=tries+1 end
	if not AdminNotif then warn("[A.APK.PANEL] AdminNotif not found"); return end

	AdminNotif.OnClientEvent:Connect(function(msg, typ)
		if typ == "bubble" then
			-- Client-side bubble creation
			local text = tostring(msg):match("BUBBLE:(.+)|COL:") or tostring(msg):match("BUBBLE:(.+)$") or ""
			local col  = tostring(msg):match("|COL:([^|]+)") or "white"
			local size = tonumber(tostring(msg):match("|SIZE:([^|]+)")) or 14
			local dur  = tonumber(tostring(msg):match("|DUR:([^|]+)"))  or 8
			local by   = tostring(msg):match("|BY:([^|]+)") or ""

			local char = lp.Character
			local hrp  = char and char:FindFirstChild("HumanoidRootPart")
			if not hrp then return end

			local old = hrp:FindFirstChild("PA_Bubble"); if old then old:Destroy() end
			local bb  = Instance.new("BillboardGui", hrp)
			bb.Name="PA_Bubble"; bb.StudsOffset=Vector3.new(0,8,0)
			bb.Size=UDim2.new(0,300,0,54); bb.MaxDistance=80
			game:GetService("Debris"):AddItem(bb, dur+1)

			local bg=Instance.new("Frame",bb); bg.Size=UDim2.new(1,0,0,46)
			bg.BackgroundColor3=Color3.fromRGB(8,8,20); bg.BorderSizePixel=0
			Corner(bg,12); Stroke(bg,C.ACC,1.5)
			local lbl=Instance.new("TextLabel",bg)
			lbl.Size=UDim2.new(1,-12,1,0); lbl.Position=UDim2.new(0,6,0,0)
			lbl.BackgroundTransparency=1; lbl.Text=text
			lbl.Font=Enum.Font.GothamBold; lbl.TextSize=size
			lbl.TextColor3=Color3.fromRGB(235,240,255); lbl.TextWrapped=true
			lbl.BorderSizePixel=0

			TS:Create(bb,TweenInfo.new(.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Size=UDim2.new(0,300,0,54)}):Play()
			task.delay(dur-1,function() if bb.Parent then TS:Create(bg,TweenInfo.new(.6),{BackgroundTransparency=1}):Play() end end)

		elseif typ == "bubble_remote" then
			local tName= tostring(msg):match("^BUBBLE_REMOTE:([^|]+)")
			local text = tostring(msg):match("|MSG:([^|]+)") or ""
			local size = tonumber(tostring(msg):match("|SIZE:([^|]+)")) or 14
			local dur  = tonumber(tostring(msg):match("|DUR:([^|]+)"))  or 8
			if not tName then return end
			local tp = Players:FindFirstChild(tName)
			local char = tp and tp.Character
			local hrp  = char and char:FindFirstChild("HumanoidRootPart")
			if not hrp then return end
			local old=hrp:FindFirstChild("PA_Bubble"); if old then old:Destroy() end
			local bb=Instance.new("BillboardGui",hrp); bb.Name="PA_Bubble"
			bb.StudsOffset=Vector3.new(0,8,0); bb.Size=UDim2.new(0,280,0,50); bb.MaxDistance=80
			game:GetService("Debris"):AddItem(bb,dur+1)
			local bg=Instance.new("Frame",bb); bg.Size=UDim2.new(1,0,0,42); bg.BackgroundColor3=Color3.fromRGB(8,8,20); bg.BorderSizePixel=0
			Corner(bg,12); Stroke(bg,C.ACC,1.5)
			local lbl=Instance.new("TextLabel",bg); lbl.Size=UDim2.new(1,-12,1,0); lbl.Position=UDim2.new(0,6,0,0)
			lbl.BackgroundTransparency=1; lbl.Text=text; lbl.Font=Enum.Font.GothamBold; lbl.TextSize=size
			lbl.TextColor3=Color3.fromRGB(235,240,255); lbl.TextWrapped=true; lbl.BorderSizePixel=0

		elseif typ == "blind" then
			if blindFr then return end
			blindFr = Frame(SG,{Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.new(0,0,0),ZIndex=99000})
		elseif typ == "unblind" then
			if blindFr then blindFr:Destroy(); blindFr=nil end
		elseif typ == "nightvision" then
			Lighting.Brightness=3; Lighting.Ambient=Color3.fromRGB(60,255,60)
			notif("🌙 Night Vision ON","success",2)
		elseif typ == "unnightvision" then
			Lighting.Brightness=2; Lighting.Ambient=Color3.fromRGB(70,70,70)
			notif("🌙 Night Vision OFF","info",2)
		elseif typ == "spectate" then
			local tName=tostring(msg):match("SPECTATE:(.+)"); if not tName then return end
			if specConn then specConn:Disconnect(); specConn=nil end
			WS.CurrentCamera.CameraType=Enum.CameraType.Scriptable
			specConn=Run.Heartbeat:Connect(function()
				local t=Players:FindFirstChild(tName)
				local h=t and t.Character and t.Character:FindFirstChild("Head")
				if h then WS.CurrentCamera.CFrame=h.CFrame*CFrame.new(0,2,7)*CFrame.Angles(-0.15,0,0) end
			end)
			notif("🔭 Spectating "..tName.." — Esc to stop","info",5)
		else
			notif(tostring(msg or ""), typ or "info")
		end
	end)
end)


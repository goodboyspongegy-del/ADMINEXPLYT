local function mkCmdBtn(par, label, col, fn, lo)
	col = col or C.ACC
	local dim = Color3.new(col.R*.14,col.G*.14,col.B*.14)
	local hov = Color3.new(col.R*.26,col.G*.26,col.B*.26)
	local btn = Button(par, {
		Text = label,
		BackgroundColor3 = dim,
		TextColor3 = col,
		TextSize = 11,
		LayoutOrder = lo or 0,
		ZIndex = 208,
	})
	Corner(btn, 8)
	Stroke(btn, Color3.new(col.R*.3,col.G*.3,col.B*.3), 1)
	Hover(btn, dim, hov)
	btn.MouseButton1Click:Connect(function()
		tween(btn,{BackgroundColor3=Color3.new(col.R*.5,col.G*.5,col.B*.5)},.05)
		task.delay(.12,function() tween(btn,{BackgroundColor3=dim},.12) end)
		local ok, err = pcall(fn)
		if not ok then notif("❌ "..tostring(err):sub(1,60),"error") end
	end)
	return btn
end


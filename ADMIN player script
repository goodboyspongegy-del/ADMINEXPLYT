-- Key system auth signal
local function checkKeyAuth()
	local s = RS:FindFirstChild("AAPK_AuthGranted")
	return s and s.Value == true
end

-- Poll for server-side admin grant
task.spawn(function()
	task.wait(2)
	local retries = 0
	while SG.Parent do
		if checkKeyAuth() then
			grantUI()
		elseif AdminQuery then
			local ok, res = pcall(function() return AdminQuery:InvokeServer("isAdmin") end)
			if ok and res and res.isAdmin then
				grantUI(); retries = 0
			else
				retries = retries + 1
				if retries >= 4 and not amOwner() and not checkKeyAuth() then
					adminOK = false
					toggleBtn.Visible = false
					glowRing.Visible  = false
					if panelOpen then closePanel() end
				end
			end
		elseif amOwner() then
			grantUI()
		end
		task.wait(6)
	end
end)


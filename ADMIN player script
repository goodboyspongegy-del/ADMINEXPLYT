	local BCOLS={{"white",C.T1},{"red",C.RED},{"green",C.GRN},{"blue",C.CYN},{"yellow",C.YEL},{"purple",C.PRP},{"pink",C.PNK},{"orange",C.ORG},{"gold",Color3.fromRGB(255,215,0)}}

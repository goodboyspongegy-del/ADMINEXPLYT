-- ════════════════════════════════════════════════════════════════
--  UI FACTORY FUNCTIONS
-- ════════════════════════════════════════════════════════════════
local function Frame(par, props)
	local f = Instance.new("Frame", par)
	f.BorderSizePixel = 0
	for k,v in pairs(props or {}) do f[k] = v end
	return f
end

local function Label(par, props)
	local l = Instance.new("TextLabel", par)
	l.BorderSizePixel = 0
	l.BackgroundTransparency = 1
	l.Font = Enum.Font.GothamBold
	l.TextColor3 = C.T1
	l.TextXAlignment = Enum.TextXAlignment.Left
	for k,v in pairs(props or {}) do l[k] = v end
	return l
end

local function Button(par, props)
	local b = Instance.new("TextButton", par)
	b.BorderSizePixel = 0
	b.AutoButtonColor = false
	b.Font = Enum.Font.GothamBold
	b.TextColor3 = C.T1
	for k,v in pairs(props or {}) do b[k] = v end
	return b
end

local function TextBox(par, props)
	local b = Instance.new("TextBox", par)
	b.BorderSizePixel = 0
	b.Font = Enum.Font.GothamMedium
	b.ClearTextOnFocus = false
	b.TextColor3 = C.T1
	for k,v in pairs(props or {}) do b[k] = v end
	return b
end

local function Scroll(par, props)
	local s = Instance.new("ScrollingFrame", par)
	s.BorderSizePixel = 0
	s.BackgroundTransparency = 1
	s.ScrollBarThickness = 3
	s.ScrollBarImageColor3 = C.ACC
	s.CanvasSize = UDim2.new(0,0,0,0)
	s.AutomaticCanvasSize = Enum.AutomaticSize.Y
	for k,v in pairs(props or {}) do s[k] = v end
	return s
end

local function Corner(obj, r)
	local c = Instance.new("UICorner", obj)
	c.CornerRadius = UDim.new(0, r or 8)
end

local function Stroke(obj, col, th)
	local e = obj:FindFirstChildOfClass("UIStroke")
	if e then e:Destroy() end
	local s = Instance.new("UIStroke", obj)
	s.Color = col or C.BORD
	s.Thickness = th or 1
	return s
end

local function Pad(obj, t, b, l, r)
	local p = Instance.new("UIPadding", obj)
	p.PaddingTop    = UDim.new(0, t or 0)
	p.PaddingBottom = UDim.new(0, b or 0)
	p.PaddingLeft   = UDim.new(0, l or 0)
	p.PaddingRight  = UDim.new(0, r or 0)
end

local function ListLayout(obj, dir, gap)
	local l = Instance.new("UIListLayout", obj)
	l.FillDirection = dir or Enum.FillDirection.Vertical
	l.SortOrder = Enum.SortOrder.LayoutOrder
	l.Padding = UDim.new(0, gap or 6)
	return l
end

local function GridLayout(obj, cs, cp)
	local g = Instance.new("UIGridLayout", obj)
	g.CellSize    = cs or UDim2.new(0,170,0,38)
	g.CellPadding = cp or UDim2.new(0,5,0,5)
	g.SortOrder   = Enum.SortOrder.LayoutOrder
	return g
end

local function Gradient(obj, c1, c2, rot)
	local g = Instance.new("UIGradient", obj)
	g.Color    = ColorSequence.new(c1, c2)
	g.Rotation = rot or 90
	return g
end

local function Hover(btn, norm, hov)
	btn.MouseEnter:Connect(function()  tween(btn,{BackgroundColor3=hov}, .12) end)
	btn.MouseLeave:Connect(function()  tween(btn,{BackgroundColor3=norm},.12) end)
end


local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- GUI
local ScreenGui = Instance.new("ScreenGui", PlayerGui)
ScreenGui.Name = "MergedAdmin"

local Main = Instance.new("Frame", ScreenGui)
Main.Size = UDim2.new(0,350,0,450)
Main.Position = UDim2.new(0.5,-175,0.5,-225)
Main.BackgroundColor3 = Color3.fromRGB(30,30,30)
Main.Active = true
Main.Draggable = true
Instance.new("UICorner", Main)

-- TITLE
local Title = Instance.new("TextLabel", Main)
Title.Size = UDim2.new(1,0,0,40)
Title.Text = "Admin Hub"
Title.BackgroundColor3 = Color3.fromRGB(50,50,50)
Title.TextColor3 = Color3.new(1,1,1)
Title.Font = Enum.Font.GothamBold

-- INPUT
local Input = Instance.new("TextBox", Main)
Input.Size = UDim2.new(1,-20,0,35)
Input.Position = UDim2.new(0,10,0,50)
Input.PlaceholderText = "Enter player name..."

-- SCROLL
local Scroll = Instance.new("ScrollingFrame", Main)
Scroll.Size = UDim2.new(1,-20,1,-100)
Scroll.Position = UDim2.new(0,10,0,90)
Scroll.CanvasSize = UDim2.new(0,0,0,0)
Scroll.BackgroundTransparency = 1

local Layout = Instance.new("UIListLayout", Scroll)
Layout.Padding = UDim.new(0,6)

Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
	Scroll.CanvasSize = UDim2.new(0,0,0,Layout.AbsoluteContentSize.Y+10)
end)

-- HELPERS
local function getPlayer(name)
	for _,p in pairs(Players:GetPlayers()) do
		if p.Name:lower():find(name:lower()) then
			return p
		end
	end
end

local function createBtn(name, func)
	local b = Instance.new("TextButton", Scroll)
	b.Size = UDim2.new(1,0,0,35)
	b.Text = name
	b.BackgroundColor3 = Color3.fromRGB(60,60,60)
	b.TextColor3 = Color3.new(1,1,1)
	b.Font = Enum.Font.GothamBold
	
	Instance.new("UICorner", b)

	b.MouseEnter:Connect(function()
		TweenService:Create(b,TweenInfo.new(0.2),{BackgroundColor3 = Color3.fromRGB(100,100,150)}):Play()
	end)

	b.MouseLeave:Connect(function()
		TweenService:Create(b,TweenInfo.new(0.2),{BackgroundColor3 = Color3.fromRGB(60,60,60)}):Play()
	end)

	b.MouseButton1Click:Connect(func)
end

-- COMMANDS

createBtn("Kill", function()
	local t = getPlayer(Input.Text)
	if t and t.Character then
		local h = t.Character:FindFirstChildOfClass("Humanoid")
		if h then h.Health = 0 end
	end
end)

createBtn("Heal", function()
	local t = getPlayer(Input.Text)
	if t and t.Character then
		local h = t.Character:FindFirstChildOfClass("Humanoid")
		if h then h.Health = h.MaxHealth end
	end
end)

createBtn("Goto", function()
	local t = getPlayer(Input.Text)
	if t and t.Character and LocalPlayer.Character then
		local root = t.Character:FindFirstChild("HumanoidRootPart")
		if root then
			LocalPlayer.Character:MoveTo(root.Position + Vector3.new(2,0,2))
		end
	end
end)

createBtn("Bring", function()
	local t = getPlayer(Input.Text)
	if t and t.Character and LocalPlayer.Character then
		local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
		if root then
			t.Character:MoveTo(root.Position + Vector3.new(2,0,2))
		end
	end
end)

createBtn("God", function()
	local h = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
	if h then
		h.MaxHealth = math.huge
		h.Health = math.huge
	end
end)

createBtn("Speed 100", function()
	local h = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
	if h then h.WalkSpeed = 100 end
end)

createBtn("Jump 150", function()
	local h = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
	if h then h.JumpPower = 150 end
end)

-- LOOPS
local followLoop

createBtn("Follow", function()
	if followLoop then
		task.cancel(followLoop)
		followLoop = nil
		return
	end

	local t = getPlayer(Input.Text)
	if t then
		followLoop = task.spawn(function()
			while true do
				if t.Character and LocalPlayer.Character then
					local root = t.Character:FindFirstChild("HumanoidRootPart")
					if root then
						LocalPlayer.Character:MoveTo(root.Position + Vector3.new(2,0,2))
					end
				end
				task.wait(0.3)
			end
		end)
	end
end)
